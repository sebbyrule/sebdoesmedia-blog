{
  "name": "sebdoesmedia-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "prebuild": "npm run projects:fetch && npm run og",
    "og": "node scripts/generate-og.mjs",
    "projects:fetch": "node scripts/fetch-github-projects.mjs",
    "pages:build": "npm run projects:fetch && npm run og && npx @opennextjs/cloudflare build",
